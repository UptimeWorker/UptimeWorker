# UptimeWorker - Environment Variables Configuration

# =============================================================================
# ⚠️  IMPORTANT: Variables Security
# =============================================================================
# VITE_* = Exposed to frontend (PUBLIC) - Use only for non-sensitive data
# No prefix = Backend only (PRIVATE) - Secure, not exposed to client

# =============================================================================
# 🎨 BRANDING CONFIGURATION
# =============================================================================
# For company-specific branding, also update src/config/branding.ts
# - Version number, company name, URLs, social links
# - Footer links (About, Terms, Privacy)
#
# Quick customization:
# 1. Update VITE_STATUS_TITLE below
# 2. Update VITE_STATUS_LOGO below
# 3. Replace logo files in public/ directory
# 4. Edit src/config/branding.ts for company details

# =============================================================================
# FRONTEND SETTINGS (VITE_* = PUBLIC)
# =============================================================================

# Site title displayed in header
# Example: "UptimeWorker" or "My Company Status"
VITE_STATUS_TITLE="UptimeWorker"

# Logo paths (relative to public folder)
# Set which logo to use for each theme
VITE_STATUS_LOGO_DARK="/logo-uptimeworker-white.webp"
VITE_STATUS_LOGO_LIGHT="/logo-uptimeworker-dark.webp"

# Frontend auto-refresh interval (in seconds) - Default: 60
VITE_REFRESH_INTERVAL=60

# Timeline history days - Default: 90
VITE_HISTORY_DAYS=90

# Enabled languages - Default: en,fr
VITE_ALLOWED_LANGS="en,fr"

# =============================================================================
# BACKEND SETTINGS (PRIVATE - Not exposed to client)
# =============================================================================

# Clé secrète pour l'endpoint /api/cron/check
# Doit être identique à CRON_SECRET configuré sur le Worker cron
CRON_SECRET=your-secret-key-here

# Intervalle entre les checks cron (en minutes)
# Doit correspondre à la config du Worker cron (* * * * * = 1 minute)
# Utilisé pour calculer le nombre de checks à stocker pour les filtres 1h/24h
CRON_CHECK_INTERVAL=1

# User-Agent pour les requêtes de monitoring
# Identifie vos requêtes auprès des services monitorés
MONITOR_USER_AGENT="UptimeWorker-Monitor/1.0"
